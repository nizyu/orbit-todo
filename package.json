{
	"name": "orbit-todo",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "biome check --write .",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:e2e:clean": "npx -y kill-port 8080 9099 36223",
		"test:e2e": "npm run test:e2e:clean && firebase emulators:exec --only auth,firestore \"npm run init:emulator && playwright test\"",
		"test:e2e:ui": "npm run test:e2e:clean && firebase emulators:exec --only auth,firestore \"npm run init:emulator && playwright test --ui\"",
		"firebase:emulators": "firebase emulators:start --only auth,firestore",
		"init:emulator": "node scripts/init-emulator-user.js",
		"local": "firebase emulators:exec --only auth,firestore \"npm run init:emulator && npm run dev\"",
		"deploy": "npm run build && firebase deploy",
		"deploy:hosting": "npm run build && firebase deploy --only hosting"
	},
	"dependencies": {
		"@tanstack/react-router": "^1.168.10",
		"firebase": "^12.11.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.1.13",
		"@tanstack/router-plugin": "^1.167.12",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"jsdom": "^29.0.1",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.1.0"
	}
}